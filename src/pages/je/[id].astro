---
export const prerender = false;

import MinimalLayout from '../../layouts/MinimalLayout.astro';
import { getDoc } from '../../lib/firestore';

Astro.response.headers.set('Cache-Control', 'no-store');

const { id } = Astro.params;
const APP_STORE_URL = 'https://apps.apple.com/app/id6777561873';

const data = await getDoc('sharedJournalEntries', id ?? '');
const notFound = !data;

const title      = data?.title     || 'An Entry';
const body       = data?.body      || null;
const entryType  = data?.entryType || 'journal';
const createdAt  = data?.createdAt || null;

const typeLabel  = entryType === 'event' ? 'Event' : 'Journal Entry';
const accentColor = entryType === 'event' ? '#7ab8d4' : '#c9a84c';
const accentDim   = entryType === 'event' ? 'rgba(122,184,212,0.3)' : 'rgba(201,168,76,0.3)';
const bgFrom      = entryType === 'event' ? '#0a1820' : '#0a1220';
const bgTo        = entryType === 'event' ? '#12243a' : '#1a1832';

const paragraphs = body ? body.split('\n').filter((p: string) => p.trim()) : [];

const formattedDate = createdAt
  ? new Date(createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;

const pageTitle = notFound
  ? `${typeLabel} · Whisp`
  : `${title} · ${typeLabel} · Whisp`;

const pageDescription = notFound
  ? 'Whisp — a journal for signs, dreams, and synchronicities.'
  : body
    ? body.slice(0, 150) + '…'
    : `${title} — a ${typeLabel.toLowerCase()} from Whisp.`;
---

<MinimalLayout
  title={pageTitle}
  description={pageDescription}
  ogUrl={`https://getwhisp.app/je/${id}`}
>

  {notFound && (
    <section class="page expired">
      <div class="wordmark">✦ whisp</div>
      <div class="starburst" aria-hidden="true">
        <svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
          <polygon
            points="45,5 49.7,27.6 65,10.4 57.7,32.3 79.6,25 62.4,40.3 85,45 62.4,49.7 79.6,65 57.7,57.7 65,79.6 49.7,62.4 45,85 40.3,62.4 25,79.6 32.3,57.7 10.4,65 27.6,49.7 5,45 27.6,40.3 10.4,25 32.3,32.3 25,10.4 40.3,27.6"
            fill="none" stroke="#c9a84c" stroke-width="0.8"
          />
        </svg>
      </div>
      <h1>This entry has faded</h1>
      <p class="subtext">Journal entries linger for a while, then return to stillness.</p>
      <a href={APP_STORE_URL} class="cta">Start your journal ✦</a>
      <p class="microcopy">Free to start · Available on iOS</p>
    </section>
  )}

  {!notFound && (
    <article class="entry-page" style={`--accent:${accentColor};--accent-dim:${accentDim};--bg-from:${bgFrom};--bg-to:${bgTo};`}>

      <!-- Hero -->
      <div class="hero">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="hero-wordmark">✦ whisp</div>
        <div class="hero-content">
          <p class="hero-eyebrow">{typeLabel.toUpperCase()}</p>
          <h1 class="hero-title">{title}</h1>
          {formattedDate && <p class="hero-date">{formattedDate}</p>}
        </div>
      </div>

      <!-- Body -->
      <div class="body">

        {paragraphs.length > 0 && (
          <div class="entry-card">
            <p class="card-eyebrow">✦ {typeLabel.toUpperCase()}</p>
            <div class="entry-text">
              {paragraphs.map((para: string) => <p>{para}</p>)}
            </div>
          </div>
        )}

        <div class="divider"></div>

        <div class="convert">
          <p class="convert-headline">Your journey, documented.</p>
          <p class="convert-body">
            Whisp is a journal for signs, synchronicities, dreams, and the
            moments that matter — with AI insights drawn from your own life.
          </p>
          <a href={APP_STORE_URL} class="cta">Start journaling ✦</a>
          <p class="microcopy">Free to start · Available on iOS</p>
        </div>

        <p class="footer-mark">getwhisp.app</p>
      </div>

    </article>
  )}

</MinimalLayout>

<style>
  /* ── Shared ─────────────────────────────────────────────────────────────────── */

  .wordmark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 26px;
    color: rgba(255, 248, 235, 0.6);
    letter-spacing: 1px;
    margin-bottom: 32px;
  }

  .starburst {
    width: 80px;
    height: 80px;
    margin-bottom: 28px;
    opacity: 0.45;
  }

  .subtext {
    font-family: 'Raleway', sans-serif;
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    max-width: 340px;
    margin: 0 0 32px;
    text-align: center;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent, #c9a84c);
    color: #0a1020;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-decoration: none;
    text-transform: uppercase;
    border-radius: 10px;
    padding: 16px 36px;
    transition: opacity 0.2s;
  }
  .cta:hover { opacity: 0.85; }

  .microcopy {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.28);
    margin-top: 12px;
    font-style: italic;
  }

  /* ── Expired ────────────────────────────────────────────────────────────────── */

  .expired {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
    background: linear-gradient(180deg, #0a1220 0%, #151830 60%, #0a1020 100%);
    color: #faf8f3;
    --accent: #c9a84c;
  }

  .expired h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 32px;
    color: #faf8f3;
    margin: 0 0 16px;
  }

  /* ── Entry page ─────────────────────────────────────────────────────────────── */

  .entry-page {
    min-height: 100vh;
    background: linear-gradient(180deg, var(--bg-from) 0%, var(--bg-to) 40%, #0a0e20 100%);
    color: #faf8f3;
  }

  /* Hero */
  .hero {
    position: relative;
    width: 100%;
    height: 48vh;
    min-height: 300px;
    max-height: 500px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 25% 50%, rgba(var(--accent), 0.12) 0%, transparent 55%),
      linear-gradient(160deg, var(--bg-from) 0%, var(--bg-to) 70%, #0a0e20 100%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 30, 0.2) 0%,
      rgba(10, 10, 30, 0.0) 30%,
      rgba(10, 10, 30, 0.65) 70%,
      rgba(10, 10, 30, 0.97) 100%
    );
  }

  .hero-wordmark {
    position: absolute;
    top: 20px;
    left: 24px;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 22px;
    color: rgba(255, 248, 235, 0.7);
    letter-spacing: 1px;
    z-index: 2;
  }

  .hero-content {
    position: absolute;
    bottom: 32px;
    left: 0;
    right: 0;
    padding: 0 24px;
    z-index: 2;
    text-align: center;
  }

  .hero-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--accent);
    margin: 0 0 12px;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(26px, 7vw, 44px);
    line-height: 1.2;
    color: #faf8f3;
    margin: 0 0 8px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  .hero-date {
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
    margin: 0;
  }

  /* Body */
  .body {
    padding: 36px 24px 72px;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .entry-card {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 0.5px solid rgba(255,255,255,0.1);
    border-left: 3px solid var(--accent-dim);
    border-radius: 16px;
    padding: 28px 24px;
    margin-bottom: 28px;
    text-align: left;
  }

  .card-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--accent);
    margin: 0 0 16px;
  }

  .entry-text p {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(17px, 4.5vw, 20px);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
    margin: 0 0 16px;
  }

  .entry-text p:last-child { margin-bottom: 0; }

  .divider {
    width: 36px;
    height: 0.5px;
    background: var(--accent-dim);
    margin: 0 auto 36px;
  }

  .convert {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .convert-headline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 26px;
    color: #faf8f3;
    margin: 0 0 14px;
    line-height: 1.3;
  }

  .convert-body {
    font-family: 'Raleway', sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    max-width: 360px;
    margin: 0 0 28px;
  }

  .footer-mark {
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.18);
    letter-spacing: 1px;
    margin-top: 40px;
  }

  @media (max-width: 480px) {
    .hero { height: 42vh; min-height: 260px; }
    .hero-title { font-size: 24px; }
    .entry-text p { font-size: 16px; }
  }
</style>
