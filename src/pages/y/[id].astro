---
export const prerender = false;

import MinimalLayout from '../../layouts/MinimalLayout.astro';
import { getDoc } from '../../lib/firestore';

Astro.response.headers.set('Cache-Control', 'no-store');

const { id } = Astro.params;
const APP_STORE_URL = 'https://apps.apple.com/app/id6777561873';

const data = await getDoc('sharedYearReviews', id ?? '');
const notFound = !data;

const reviewYear     = data?.reviewYear     || null;
const ownerName      = data?.ownerDisplayName || null;
const totalLogs      = data?.totalLogs      || 0;
const uniqueDays     = data?.uniqueDays     || 0;
const longestStreak  = data?.longestStreak  || 0;
const mostActiveMonth = data?.mostActiveMonth || null;
const topSymbols     = (data?.topSymbols    || []) as { name: string; count: number }[];
const narrative      = data?.narrative      || null;

const paragraphs = narrative ? narrative.split('\n').filter((p: string) => p.trim()) : [];

const pageTitle = reviewYear
  ? `My ${reviewYear} Year in Review · Whisp`
  : 'A Year in Review · Whisp';

const pageDescription = !notFound
  ? `${totalLogs} signs noticed, ${uniqueDays} days of awareness, a ${longestStreak}-day streak.`
  : 'Whisp — a journal for signs, dreams, and synchronicities.';
---

<MinimalLayout
  title={pageTitle}
  description={pageDescription}
  ogImage="https://getwhisp.app/icon.png"
  ogUrl={`https://getwhisp.app/y/${id}`}
  twitterCard="summary"
>

  {notFound && (
    <section class="page expired">
      <div class="wordmark">✦ whisp</div>
      <div class="starburst" aria-hidden="true">
        <svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
          <polygon
            points="45,5 49.7,27.6 65,10.4 57.7,32.3 79.6,25 62.4,40.3 85,45 62.4,49.7 79.6,65 57.7,57.7 65,79.6 49.7,62.4 45,85 40.3,62.4 25,79.6 32.3,57.7 10.4,65 27.6,49.7 5,45 27.6,40.3 10.4,25 32.3,32.3 25,10.4 40.3,27.6"
            fill="none" stroke="#c9a84c" stroke-width="0.8"
          />
        </svg>
      </div>
      <h1>This year in review has faded</h1>
      <p class="subtext">Yearly reflections linger for a while, then dissolve — like the signs themselves.</p>
      <a href={APP_STORE_URL} class="cta">Build your own year ✦</a>
      <p class="microcopy">Free to start · Available on iOS</p>
    </section>
  )}

  {!notFound && (
    <article class="year-page">

      <!-- Hero -->
      <div class="hero">
        <div class="hero-overlay"></div>
        <div class="hero-wordmark">✦ whisp</div>

        <div class="hero-content">
          <p class="hero-eyebrow">
            {ownerName ? `${ownerName}'s year in review` : 'A YEAR IN REVIEW'}
          </p>
          {reviewYear && <h1 class="hero-year">{reviewYear}</h1>}
          <p class="hero-tagline">A year of noticing</p>
        </div>
      </div>

      <!-- Body -->
      <div class="body">

        <div class="stat-grid">
          <div class="stat">
            <span class="stat-num">{totalLogs}</span>
            <span class="stat-label">Signs noticed</span>
          </div>
          <div class="stat">
            <span class="stat-num">{uniqueDays}</span>
            <span class="stat-label">Days of awareness</span>
          </div>
          <div class="stat">
            <span class="stat-num">{longestStreak}</span>
            <span class="stat-label">Longest streak</span>
          </div>
        </div>

        {mostActiveMonth && (
          <p class="active-month">Most active in <strong>{mostActiveMonth}</strong></p>
        )}

        {topSymbols.length > 0 && (
          <div class="symbols-section">
            <p class="section-label">TOP SIGNS</p>
            <div class="symbol-pills">
              {topSymbols.slice(0, 6).map((s) => (
                <div class="symbol-pill">
                  <span class="symbol-name">{s.name}</span>
                  {s.count > 1 && <span class="symbol-count">×{s.count}</span>}
                </div>
              ))}
            </div>
          </div>
        )}

        {paragraphs.length > 0 && (
          <div class="narrative-card">
            <p class="narrative-eyebrow">✦ WHISP'S REFLECTION</p>
            <div class="narrative-text">
              {paragraphs.map((para: string) => <p>{para}</p>)}
            </div>
          </div>
        )}

        <div class="divider"></div>

        <div class="convert">
          <p class="convert-headline">What will <em>your</em> year look like?</p>
          <p class="convert-body">
            Whisp tracks the signs, dreams, and synchronicities you notice
            all year long, then weaves them into a story at year's end.
          </p>
          <a href={APP_STORE_URL} class="cta">Download Whisp ✦</a>
          <p class="microcopy">Free to start · Available on iOS</p>
        </div>

        <p class="footer-mark">getwhisp.app</p>
      </div>

    </article>
  )}

</MinimalLayout>

<style>
  /* ── Shared ─────────────────────────────────────────────────────────────────── */

  .wordmark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 26px;
    color: rgba(255, 248, 235, 0.6);
    letter-spacing: 1px;
    margin-bottom: 32px;
  }

  .starburst {
    width: 80px;
    height: 80px;
    margin-bottom: 28px;
    opacity: 0.5;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #c9a84c;
    color: #0a0e20;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-decoration: none;
    text-transform: uppercase;
    border-radius: 10px;
    padding: 16px 36px;
    transition: opacity 0.2s;
  }
  .cta:hover { opacity: 0.85; }

  .microcopy {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.28);
    margin-top: 12px;
    font-style: italic;
  }

  .subtext {
    font-family: 'Raleway', sans-serif;
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    max-width: 340px;
    margin: 0 0 32px;
    text-align: center;
  }

  /* ── Expired ────────────────────────────────────────────────────────────────── */

  .expired {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
    background: linear-gradient(180deg, #0a1020 0%, #1c1530 60%, #0a1020 100%);
    color: #faf8f3;
  }

  .expired h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 32px;
    color: #faf8f3;
    margin: 0 0 16px;
  }

  /* ── Year page ──────────────────────────────────────────────────────────────── */

  .year-page {
    min-height: 100vh;
    background: #0a1020;
    color: #faf8f3;
  }

  /* Hero */
  .hero {
    position: relative;
    width: 100%;
    padding: 64px 24px 48px;
    overflow: hidden;
    text-align: center;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(201, 168, 76, 0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 70%, rgba(140, 100, 200, 0.22) 0%, transparent 55%),
      linear-gradient(160deg, #0c0a1e 0%, #1a1240 50%, #0a1020 100%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10,8,30,0) 0%, rgba(10,16,32,0.9) 100%);
  }

  .hero-wordmark {
    position: relative;
    z-index: 2;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 22px;
    color: rgba(255, 248, 235, 0.7);
    letter-spacing: 1px;
    margin-bottom: 28px;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0 0 14px;
  }

  .hero-year {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(56px, 16vw, 96px);
    line-height: 1;
    color: #faf8f3;
    margin: 0 0 10px;
    text-shadow: 0 4px 30px rgba(201, 168, 76, 0.25);
  }

  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  /* Body */
  .body {
    padding: 40px 24px 72px;
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stat-grid {
    display: flex;
    width: 100%;
    justify-content: space-around;
    gap: 12px;
    margin-bottom: 18px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(30px, 8vw, 40px);
    color: #c9a84c;
    line-height: 1;
  }

  .stat-label {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .active-month {
    font-family: 'Raleway', sans-serif;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    margin: 0 0 28px;
  }

  .active-month strong {
    color: rgba(255, 255, 255, 0.75);
    font-weight: 600;
  }

  .section-label {
    font-family: 'Raleway', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(201, 168, 76, 0.6);
    margin: 0 0 14px;
  }

  .symbols-section {
    width: 100%;
    margin-bottom: 28px;
  }

  .symbol-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .symbol-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px;
    color: #c9a84c;
    border: 0.5px solid rgba(201, 168, 76, 0.35);
    background: rgba(201, 168, 76, 0.07);
    border-radius: 999px;
    padding: 8px 20px;
  }

  .symbol-count {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    color: rgba(201, 168, 76, 0.55);
    font-weight: 500;
  }

  .narrative-card {
    width: 100%;
    background: rgba(201, 168, 76, 0.05);
    border: 0.5px solid rgba(201, 168, 76, 0.2);
    border-left: 3px solid rgba(201, 168, 76, 0.45);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 28px;
    text-align: left;
  }

  .narrative-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    color: #c9a84c;
    margin: 0 0 14px;
  }

  .narrative-text p {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(16px, 4.2vw, 19px);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
    margin: 0 0 16px;
  }

  .narrative-text p:last-child { margin-bottom: 0; }

  .divider {
    width: 36px;
    height: 0.5px;
    background: rgba(201, 168, 76, 0.35);
    margin: 0 auto 36px;
  }

  .convert {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .convert-headline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 25px;
    color: #faf8f3;
    margin: 0 0 14px;
    line-height: 1.3;
  }

  .convert-headline em {
    font-style: italic;
    color: #c9a84c;
  }

  .convert-body {
    font-family: 'Raleway', sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    max-width: 360px;
    margin: 0 0 28px;
  }

  .footer-mark {
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.18);
    letter-spacing: 1px;
    margin-top: 40px;
  }

  @media (max-width: 480px) {
    .hero { padding: 52px 20px 40px; }
    .stat-grid { gap: 4px; }
  }
</style>
