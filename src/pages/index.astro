  <script>
    // App slides carousel
    const slidesEl   = document.getElementById('slides-scroll') as HTMLElement | null;
    const slideCards = document.querySelectorAll<HTMLElement>('.slide-card');
    const slideDots  = document.querySelectorAll<HTMLElement>('#sc-dots .sc-dot');
    let slideCur = 0;
    const slideTot = 6;

    function getScrollPad() {
      if (!slidesEl) return 0;
      return parseInt(getComputedStyle(slidesEl).paddingLeft) || 0;
    }

    function slideTo(idx: number) {
      slideCur = ((idx % slideTot) + slideTot) % slideTot;
      const card = slideCards[slideCur];
      if (card && slidesEl) {
        slidesEl.scrollTo({ left: card.offsetLeft - getScrollPad(), behavior: 'smooth' });
      }
      slideDots.forEach((d, i) => d.classList.toggle('active', i === slideCur));
    }

    document.getElementById('sc-prev')?.addEventListener('click', () => slideTo(slideCur - 1));
    document.getElementById('sc-next')?.addEventListener('click', () => slideTo(slideCur + 1));
    slideDots.forEach(d => d.addEventListener('click', () => slideTo(Number(d.dataset.idx))));

    // Auto-advance
    let slideTimer = setInterval(() => slideTo(slideCur + 1), 6500);
    slidesEl?.addEventListener('pointerdown', () => { clearInterval(slideTimer); slideTimer = setInterval(() => slideTo(slideCur + 1), 6500); });

    // Sync dot on native scroll
    if (typeof IntersectionObserver !== 'undefined' && slidesEl) {
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const i = Array.from(slideCards).indexOf(e.target as HTMLElement);
            if (i !== -1) { slideCur = i; slideDots.forEach((d, j) => d.classList.toggle('active', j === i)); }
          }
        });
      }, { root: slidesEl, threshold: 0.55 });
      slideCards.forEach(c => io.observe(c));
    }
  </script>

