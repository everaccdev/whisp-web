---
export const prerender = true;
import Base from '../layouts/Base.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<Base>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero">
    <!-- Full-bleed painterly background -->
    <div class="hero-bg-img"></div>
    <div class="hero-overlay"></div>

    <div class="hero-content">
      <div class="hero-eyebrow fade-up">
        <span class="hero-glyph">✦</span>
        <span class="hero-label">A JOURNAL FOR SIGNS & SYNCHRONICITY</span>
      </div>

      <div class="hero-logo-wrap fade-up" style="animation-delay:0.08s">
        <span class="hero-logo-mark">✦ whisp</span>
      </div>

      <h1 class="hero-title fade-up" style="animation-delay:0.15s">
        The universe is always<br /><em>speaking.</em>
      </h1>

      <div class="hero-rule fade-up" style="animation-delay:0.22s">
        <div class="rule-line"></div>
      </div>

      <p class="hero-sub fade-up" style="animation-delay:0.28s">
        Track signs, synchronicities, dreams, and symbols.<br />
        Discover what they mean — for <em>you</em>.
      </p>

      <div class="hero-cta fade-up" style="animation-delay:0.36s">
        <EmailCapture variant="hero" label="Get Early Access" />
      </div>

      <p class="hero-note fade-up" style="animation-delay:0.44s">
        ✦ &nbsp;Free to start &nbsp;·&nbsp; iOS & Android &nbsp;·&nbsp; Coming soon
      </p>
    </div>

    <div class="hero-scroll-hint">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════ QUOTE CAROUSEL ═══════════════ -->
  <section class="quotes" id="quotes">
    <div class="quotes-track" id="quotes-track">

      <div class="quote-slide" style="--bg: url('/quote-1.png')">
        <div class="quote-bg"></div>
        <div class="quote-body">
          <div class="quote-category">
            <span class="q-glyph">✦</span>
            <span>ON SYNCHRONICITY</span>
          </div>
          <div class="q-rule"></div>
          <blockquote>"Coincidence is God's way of remaining anonymous."</blockquote>
          <cite>~ Albert Einstein</cite>
        </div>
        <div class="slide-logo">✦ whisp</div>
      </div>

      <div class="quote-slide" style="--bg: url('/quote-2.png')">
        <div class="quote-bg"></div>
        <div class="quote-body">
          <div class="quote-category">
            <span class="q-glyph">✦</span>
            <span>ON SIGNS</span>
          </div>
          <div class="q-rule"></div>
          <blockquote>"The universe is always speaking to us… sending us little messages, causing coincidences and serendipities, reminding us to stop, to look around, to believe in something more."</blockquote>
          <cite>~ Nancy Thayer</cite>
        </div>
        <div class="slide-logo">✦ whisp</div>
      </div>

      <div class="quote-slide" style="--bg: url('/quote-3.png')">
        <div class="quote-bg"></div>
        <div class="quote-body">
          <div class="quote-category">
            <span class="q-glyph">✦</span>
            <span>CARL JUNG</span>
          </div>
          <div class="q-rule"></div>
          <blockquote>"Synchronicity is an ever-present reality for those who have eyes to see."</blockquote>
          <cite>~ Carl Jung</cite>
        </div>
        <div class="slide-logo">✦ whisp</div>
      </div>

      <div class="quote-slide" style="--bg: url('/quote-4.png')">
        <div class="quote-bg"></div>
        <div class="quote-body">
          <div class="quote-category">
            <span class="q-glyph">✦</span>
            <span>ON NOTICING</span>
          </div>
          <div class="q-rule"></div>
          <blockquote>"When you live your life with an appreciation of coincidences and their meanings, you connect with the underlying field of infinite possibilities."</blockquote>
          <cite>~ Deepak Chopra</cite>
        </div>
        <div class="slide-logo">✦ whisp</div>
      </div>

    </div>

    <!-- Navigation -->
    <div class="quotes-nav">
      <button class="q-btn" id="q-prev" aria-label="Previous">←</button>
      <div class="q-dots" id="q-dots">
        <button class="q-dot active" data-idx="0"></button>
        <button class="q-dot" data-idx="1"></button>
        <button class="q-dot" data-idx="2"></button>
        <button class="q-dot" data-idx="3"></button>
      </div>
      <button class="q-btn" id="q-next" aria-label="Next">→</button>
    </div>
  </section>

  <script>
    // Quote carousel
    const track = document.getElementById('quotes-track');
    const dots = document.querySelectorAll('.q-dot');
    let current = 0;
    const total = 4;

    function goTo(idx) {
      current = (idx + total) % total;
      if (track) (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    document.getElementById('q-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('q-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach(d => d.addEventListener('click', () => goTo(Number(d.getAttribute('data-idx')))));

    // Auto-advance
    setInterval(() => goTo(current + 1), 7000);

    // Touch/swipe
    let touchStartX = 0;
    track?.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; });
    track?.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
    });
  </script>

  <!-- ═══════════════ FEATURES ═══════════════ -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <span class="section-label">What Whisp does</span>
        <h2 class="section-title">Your signs. Your meaning.</h2>
        <p class="section-sub">
          Not generic horoscopes. Not one-size-fits-all interpretations.<br />
          Whisp learns your cosmology and reflects it back to you.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card feature-card--large">
          <div class="feature-icon">◐</div>
          <h3>Sign & Dream Logging</h3>
          <p>Capture repeating numbers, animals, dreams, and symbols the moment they happen. Quick, frictionless, and beautiful.</p>
          <div class="feature-tag">Core</div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">⟁</div>
          <h3>Pattern Intelligence</h3>
          <p>Whisp surfaces correlations across your logs — symbols that cluster around emotional states, moon phases, or life events.</p>
          <div class="feature-tag feature-tag--gold">Premium</div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">◎</div>
          <h3>Personal Symbol Library</h3>
          <p>Every symbol builds a profile over time. See frequency, emotional tone, and personalized AI reflections that remember your beliefs.</p>
          <div class="feature-tag feature-tag--gold">Premium</div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">☽</div>
          <h3>Celestial Context</h3>
          <p>Moon phases, retrogrades, eclipses, and your natal chart woven into every log — gated by what you actually believe in.</p>
          <div class="feature-tag">Core</div>
        </div>

        <div class="feature-card feature-card--large">
          <div class="feature-icon">✦</div>
          <h3>Belief-Aware AI</h3>
          <p>Choose your cosmology — astrology, numerology, Jungian, spiritual, secular — and Whisp's AI only draws on the lenses you've selected. Your meaning, not ours.</p>
          <div class="feature-tag feature-tag--gold">Premium</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ HOW IT WORKS ═══════════════ -->
  <section class="how-it-works" id="how-it-works">
    <div class="container">
      <div class="section-header">
        <span class="section-label">The journey</span>
        <h2 class="section-title">From sign to meaning</h2>
      </div>

      <div class="steps">
        <div class="step">
          <div class="step-number">01</div>
          <div class="step-content">
            <h3>Log the moment</h3>
            <p>A quick tap captures the sign — what you saw, felt, and where you were. Dream, symbol, repeating number, animal encounter. Nothing gets lost.</p>
          </div>
        </div>
        <div class="step-connector">· · ·</div>

        <div class="step">
          <div class="step-number">02</div>
          <div class="step-content">
            <h3>Whisp finds the patterns</h3>
            <p>Over days and weeks, your personal intelligence model builds. Whisp surfaces what's repeating, what shifts with your mood, what clusters around certain times.</p>
          </div>
        </div>
        <div class="step-connector">· · ·</div>

        <div class="step">
          <div class="step-number">03</div>
          <div class="step-content">
            <h3>Meaning that's yours</h3>
            <p>AI reflections that know your beliefs, your life context, and your resonance history. Not a generic interpretation — a conversation with your own emerging mythology.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PHILOSOPHY ═══════════════ -->
  <section class="philosophy">
    <div class="container">
      <div class="philosophy-inner">
        <div class="philosophy-glyph" aria-hidden="true">✦</div>
        <blockquote class="philosophy-quote">
          "The universe speaks in symbols.<br />Whisp helps you learn the language."
        </blockquote>
        <p class="philosophy-body">
          We believe meaning isn't universal — it's personal. What a crow means to you is shaped by your history, your beliefs, your culture, and the moment it appeared.
          Whisp doesn't tell you what your signs mean. It helps you discover it yourself.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PRICING ═══════════════ -->
  <section class="pricing" id="pricing">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Founding member offer</span>
        <h2 class="section-title">Start free. Go deeper.</h2>
        <p class="section-sub">Whisp is free to start. Premium unlocks personalized AI and pattern intelligence.</p>
      </div>

      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-tier">Free</div>
          <div class="pricing-price">
            <span class="price-amount">$0</span>
            <span class="price-period">forever</span>
          </div>
          <ul class="pricing-features">
            <li>✓ Unlimited sign & dream logging</li>
            <li>✓ Symbol library (universal meanings)</li>
            <li>✓ Celestial context</li>
            <li>✓ Basic pattern tracking</li>
          </ul>
          <a href="#early-access" class="btn btn-outline" style="width:100%; justify-content:center;">Join waitlist</a>
        </div>

        <div class="pricing-card pricing-card--featured">
          <div class="pricing-badge">Founding Member</div>
          <div class="pricing-tier">Premium</div>
          <div class="pricing-price">
            <span class="price-amount">$3.99</span>
            <span class="price-period">/month · limited offer</span>
          </div>
          <p class="pricing-note">Lock in founder pricing forever. Normally $6.99/mo.</p>
          <ul class="pricing-features">
            <li>✓ Everything in Free</li>
            <li>✓ Personalized AI reflections</li>
            <li>✓ Deep pattern intelligence</li>
            <li>✓ Symbol resonance learning</li>
            <li>✓ Synthesis letters & insights</li>
            <li>✓ Belief-aware interpretation</li>
          </ul>
          <!-- Replace href with your Stripe Payment Link -->
          <a href="#early-access" class="btn btn-primary" style="width:100%; justify-content:center;">Claim founder pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FINAL CTA ═══════════════ -->
  <section class="final-cta">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-glyph" aria-hidden="true">◎</div>
        <h2>Your signs are waiting</h2>
        <p>Be among the first to hear what they're saying.</p>
        <EmailCapture variant="hero" label="Get Early Access" />
      </div>
    </div>
  </section>
</Base>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    overflow: hidden;
    position: relative;
  }
  .hero-bg-img {
    position: absolute;
    inset: 0;
    background-image: url('/hero-bg-1.png');
    background-size: cover;
    background-position: center 20%;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to bottom,
        rgba(8,12,24,0.55) 0%,
        rgba(8,12,24,0.25) 40%,
        rgba(8,12,24,0.6) 75%,
        rgba(8,12,24,0.92) 100%
      );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    padding: 160px clamp(24px,5vw,64px) 120px;
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-glyph {
    color: var(--gold);
    font-size: 0.7rem;
    opacity: 0.8;
  }
  .hero-label {
    font-family: var(--font-display);
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.75;
  }
  .hero-logo-wrap {
    margin: 8px 0 4px;
  }
  .hero-logo-mark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(36px, 5vw, 52px);
    color: rgba(255, 248, 235, 0.7);
    letter-spacing: 0.05em;
    text-shadow: 0 2px 32px rgba(201, 168, 76, 0.25);
  }
  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--cream);
    text-shadow: 0 2px 32px rgba(0,0,0,0.6);
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold-light);
  }
  .hero-rule {
    display: flex;
    align-items: center;
    width: 120px;
  }
  .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  }
  .hero-sub {
    max-width: 520px;
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--cream-dim);
    font-family: var(--font-heading);
    font-weight: 300;
    line-height: 1.75;
    text-shadow: 0 1px 12px rgba(0,0,0,0.5);
  }
  .hero-sub em { font-style: italic; color: var(--cream); }
  .hero-cta { width: 100%; display: flex; justify-content: center; }
  .hero-note {
    font-size: 0.75rem;
    color: rgba(200,196,184,0.4);
    letter-spacing: 0.08em;
    font-family: var(--font-display);
  }
  .hero-scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.3;
  }
  .hero-scroll-hint span {
    font-family: var(--font-display);
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cream);
  }
  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--cream), transparent);
    animation: scrollPulse 2s ease infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 0.7; transform: scaleY(1); }
  }

  /* ── QUOTE CAROUSEL ── */
  .quotes {
    position: relative;
    overflow: hidden;
    background: #060a12;
  }
  .quotes-track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.77,0,0.175,1);
    will-change: transform;
  }
  .quote-slide {
    flex: 0 0 100%;
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .quote-bg {
    position: absolute;
    inset: 0;
    background-image: var(--bg);
    background-size: cover;
    background-position: center 25%;
    transition: transform 0.6s ease;
  }
  .quote-slide::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(6,10,18,0.1) 0%,
      rgba(6,10,18,0.3) 40%,
      rgba(6,10,18,0.75) 65%,
      rgba(6,10,18,0.97) 100%
    );
  }
  .quote-body {
    position: relative;
    z-index: 2;
    padding: clamp(40px,6vw,80px) clamp(28px,6vw,80px) 100px;
    max-width: 820px;
  }
  .quote-category {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .q-glyph {
    color: var(--gold);
    font-size: 0.7rem;
  }
  .quote-category span:last-child {
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.8;
  }
  .q-rule {
    width: 48px;
    height: 1px;
    background: var(--gold-dim);
    margin-bottom: 24px;
    opacity: 0.6;
  }
  .quote-body blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    font-weight: 300;
    font-style: italic;
    color: var(--cream);
    line-height: 1.45;
    margin-bottom: 20px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .quote-body cite {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-style: italic;
    color: var(--gold);
    opacity: 0.85;
  }
  .slide-logo {
    position: absolute;
    bottom: 28px;
    left: clamp(28px,6vw,80px);
    z-index: 2;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 16px;
    color: rgba(255, 248, 235, 0.35);
    letter-spacing: 0.05em;
  }
  .quotes-nav {
    position: absolute;
    bottom: 28px;
    right: clamp(28px,4vw,60px);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .q-btn {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(201,168,76,0.2);
    color: var(--cream-dim);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    backdrop-filter: blur(4px);
  }
  .q-btn:hover {
    border-color: var(--gold-dim);
    color: var(--gold-light);
  }
  .q-dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .q-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(200,196,184,0.25);
    border: none;
    cursor: pointer;
    transition: all 0.25s;
    padding: 0;
  }
  .q-dot.active {
    background: var(--gold);
    transform: scale(1.3);
  }

  /* ── FEATURES ── */
  .features { padding: var(--section-pad) 0; }
  .section-header {
    text-align: center;
    margin-bottom: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--cream);
    font-weight: 300;
  }
  .section-sub {
    max-width: 520px;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--cream-dim);
    text-align: center;
    line-height: 1.7;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .feature-card--large { grid-column: span 2; }
  .feature-card {
    background: rgba(15, 24, 48, 0.6);
    border: 1px solid var(--navy-border);
    border-radius: 8px;
    padding: 36px;
    position: relative;
    transition: border-color 0.3s, transform 0.3s;
  }
  .feature-card:hover {
    border-color: rgba(201,168,76,0.25);
    transform: translateY(-3px);
  }
  .feature-icon {
    font-size: 1.8rem;
    color: var(--gold);
    opacity: 0.7;
    margin-bottom: 20px;
    line-height: 1;
  }
  .feature-card h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 500;
    margin-bottom: 12px;
    color: var(--cream);
  }
  .feature-card p {
    font-size: 0.9rem;
    color: var(--cream-dim);
    line-height: 1.7;
  }
  .feature-tag {
    position: absolute;
    top: 20px;
    right: 20px;
    font-family: var(--font-display);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    background: rgba(30, 45, 80, 0.8);
    color: var(--cream-dim);
    border: 1px solid var(--navy-border);
  }
  .feature-tag--gold {
    background: rgba(201, 168, 76, 0.1);
    color: var(--gold);
    border-color: rgba(201, 168, 76, 0.2);
  }

  /* ── HOW IT WORKS ── */
  .how-it-works { padding: var(--section-pad) 0; }
  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 700px;
    margin: 0 auto;
  }
  .step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    padding: 40px 0;
    border-bottom: 1px solid rgba(30, 45, 80, 0.4);
  }
  .step:last-child { border-bottom: none; }
  .step-number {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--gold);
    opacity: 0.5;
    padding-top: 6px;
  }
  .step-content h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 12px;
