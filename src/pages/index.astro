      <div class="sc-dots" id="sc-dots">
        <button class="sc-dot active" data-idx="0"></button>
        <button class="sc-dot" data-idx="1"></button>
        <button class="sc-dot" data-idx="2"></button>
        <button class="sc-dot" data-idx="3"></button>
        <button class="sc-dot" data-idx="4"></button>
        <button class="sc-dot" data-idx="5"></button>
      </div>
      <button class="sc-btn" id="sc-next" aria-label="Next">→</button>
    </div>
