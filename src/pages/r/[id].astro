---
export const prerender = false;

import MinimalLayout from '../../layouts/MinimalLayout.astro';
import { getDoc } from '../../lib/firestore';

Astro.response.headers.set('Cache-Control', 'no-store');

const { id } = Astro.params;
const APP_STORE_URL = 'https://apps.apple.com/app/id6777561873';

const data = await getDoc('sharedReadings', id ?? '');
const notFound = !data;
const hasImage = !notFound && !!data?.imageUrl;

const recipientName  = data?.recipientName   || null;
const ownerName      = data?.ownerDisplayName || null;
const noticing       = (data?.noticing        || {}) as Record<string, any>;
const signs          = (noticing.signs        || []) as string[];
const reading        = data?.reading          || '';
const imageUrl       = data?.imageUrl         || null;

// Build context sentence
const noticingParts: string[] = [];
if (noticing.hasDream) noticingParts.push('a dream');
if (signs.length) {
  noticingParts.push(
    signs.length > 1
      ? `${signs.length} signs they keep noticing`
      : `"${signs[0]}"`
  );
}
if (noticing.hasSituation && !noticing.hasDream && !signs.length) {
  noticingParts.push("what's been going on in their life");
}
const contextLine = noticingParts.length
  ? `Based on ${noticingParts.join(' and ')} shared with Whisp.`
  : null;

const paragraphs = reading.split('\n').filter((p: string) => p.trim());

const pageTitle = recipientName
  ? `A reading for ${recipientName} ✦ Whisp`
  : 'A reading from Whisp ✦';

const pageDescription = !notFound && reading
  ? String(reading).slice(0, 150) + '…'
  : 'Whisp — a journal for signs, dreams, and synchronicities.';
---

<MinimalLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={hasImage ? imageUrl : '/og-image.jpg'}
  ogUrl={`https://getwhisp.app/r/${id}`}
  twitterCard={hasImage ? 'summary_large_image' : 'summary'}
>

  {notFound && (
    <section class="page expired">
      <div class="wordmark">✦ whisp</div>
      <div class="starburst" aria-hidden="true">
        <svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
          <polygon
            points="45,5 49.7,27.6 65,10.4 57.7,32.3 79.6,25 62.4,40.3 85,45 62.4,49.7 79.6,65 57.7,57.7 65,79.6 49.7,62.4 45,85 40.3,62.4 25,79.6 32.3,57.7 10.4,65 27.6,49.7 5,45 27.6,40.3 10.4,25 32.3,32.3 25,10.4 40.3,27.6"
            fill="none" stroke="#c9a84c" stroke-width="0.8"
          />
        </svg>
      </div>
      <h1>This reading has faded</h1>
      <p class="subtext">
        Gifted readings linger for a while, then return to the ether — as the signs themselves do.
      </p>
      <a href={APP_STORE_URL} class="cta">Get readings of your own ✦</a>
      <p class="microcopy">Free to start · Available on iOS</p>
    </section>
  )}

  {!notFound && (
    <article class="reading-page">

      <!-- ── Hero ──────────────────────────────────────────────────────────── -->
      <div class="hero">
        {hasImage ? (
          <img src={imageUrl} alt="A reading for you" class="hero-img" />
        ) : (
          <div class="hero-fallback"></div>
        )}
        <div class="hero-overlay"></div>

        <!-- Starburst watermark -->
        <div class="hero-starburst" aria-hidden="true">
          <svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
            <polygon
              points="45,5 49.7,27.6 65,10.4 57.7,32.3 79.6,25 62.4,40.3 85,45 62.4,49.7 79.6,65 57.7,57.7 65,79.6 49.7,62.4 45,85 40.3,62.4 25,79.6 32.3,57.7 10.4,65 27.6,49.7 5,45 27.6,40.3 10.4,25 32.3,32.3 25,10.4 40.3,27.6"
              fill="none" stroke="rgba(201,168,76,0.5)" stroke-width="0.8"
            />
          </svg>
        </div>

        <div class="hero-wordmark">✦ whisp</div>

        <div class="hero-title-block">
          <p class="hero-eyebrow">
            {ownerName ? `${ownerName} thought of you` : 'Someone thought of you'}
          </p>
          <h1 class="hero-title">
            {recipientName
              ? <><span>A reading for </span><em>{recipientName}</em></>
              : <><span>A reading </span><em>for you</em></>}
          </h1>
        </div>
      </div>

      <!-- ── Body ──────────────────────────────────────────────────────────── -->
      <div class="body">

        {signs.length > 0 && (
          <div class="sign-pills">
            {signs.map((s: string) => (
              <div class="sign-pill">{s}</div>
            ))}
          </div>
        )}

        {contextLine && (
          <p class="reading-context">{contextLine}</p>
        )}

        <div class="reading-card">
          <p class="reading-eyebrow">✦ WHISP'S READING</p>
          <div class="reading-text">
            {paragraphs.map((para: string) => <p>{para}</p>)}
          </div>
        </div>

        <div class="divider"></div>

        <div class="convert">
          <p class="convert-headline">Curious what <em>your</em> signs mean?</p>
          <p class="convert-body">
            Whisp is a journal for the signs, symbols, and synchronicities
            you notice every day — with personal AI readings drawn from your
            own life and beliefs.
          </p>
          <a href={APP_STORE_URL} class="cta">Download Whisp ✦</a>
          <p class="microcopy">Free to start · Available on iOS</p>
        </div>

        <p class="footer-mark">getwhisp.app</p>
      </div>

    </article>
  )}

</MinimalLayout>

<style>
  /* ── Shared ─────────────────────────────────────────────────────────────────── */

  .wordmark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 26px;
    color: rgba(255, 248, 235, 0.6);
    letter-spacing: 1px;
    margin-bottom: 32px;
  }

  .starburst {
    width: 80px;
    height: 80px;
    margin-bottom: 28px;
    opacity: 0.5;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #c9a84c;
    color: #0a0e20;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-decoration: none;
    text-transform: uppercase;
    border-radius: 10px;
    padding: 16px 36px;
    transition: opacity 0.2s;
  }
  .cta:hover { opacity: 0.85; }

  .microcopy {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.28);
    margin-top: 12px;
    font-style: italic;
  }

  .subtext {
    font-family: 'Raleway', sans-serif;
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    max-width: 340px;
    margin: 0 0 32px;
    text-align: center;
  }

  /* ── Expired ────────────────────────────────────────────────────────────────── */

  .expired {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
    background: linear-gradient(180deg, #0c0a1e 0%, #1a1030 60%, #0c0a1e 100%);
    color: #faf8f3;
  }

  .expired h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 32px;
    color: #faf8f3;
    margin: 0 0 16px;
  }

  /* ── Reading page ───────────────────────────────────────────────────────────── */

  .reading-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #0c0a1e 0%, #1a1030 40%, #0a0e20 100%);
    color: #faf8f3;
  }

  /* Hero */
  .hero {
    position: relative;
    width: 100%;
    height: 62vh;
    min-height: 400px;
    max-height: 620px;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .hero-fallback {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 40%, rgba(140, 100, 200, 0.45) 0%, transparent 60%),
      radial-gradient(ellipse at 75% 60%, rgba(201, 168, 76, 0.2) 0%, transparent 55%),
      linear-gradient(160deg, #0c0a1e 0%, #1e1040 50%, #0a0e20 100%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 8, 30, 0.3) 0%,
      rgba(10, 8, 30, 0.0) 28%,
      rgba(10, 8, 30, 0.55) 65%,
      rgba(10, 8, 30, 0.97) 100%
    );
  }

  .hero-starburst {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 160px;
    height: 160px;
    opacity: 0.12;
    z-index: 1;
  }

  .hero-wordmark {
    position: absolute;
    top: 20px;
    left: 24px;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 22px;
    color: rgba(255, 248, 235, 0.7);
    letter-spacing: 1px;
    z-index: 2;
  }

  .hero-title-block {
    position: absolute;
    bottom: 32px;
    left: 0;
    right: 0;
    padding: 0 24px;
    z-index: 2;
    text-align: center;
  }

  .hero-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0 0 12px;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(28px, 7vw, 46px);
    line-height: 1.15;
    color: #faf8f3;
    margin: 0;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.6);
  }

  .hero-title em {
    font-style: italic;
    color: #c9a84c;
  }

  /* Body */
  .body {
    padding: 36px 24px 72px;
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .sign-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 20px;
  }

  .sign-pill {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px;
    color: #c9a84c;
    border: 0.5px solid rgba(201, 168, 76, 0.4);
    background: rgba(201, 168, 76, 0.07);
    border-radius: 999px;
    padding: 8px 22px;
  }

  .reading-context {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.38);
    margin-bottom: 28px;
    font-style: italic;
  }

  .reading-card {
    width: 100%;
    background: rgba(201, 168, 76, 0.06);
    border: 0.5px solid rgba(201, 168, 76, 0.18);
    border-left: 3px solid rgba(201, 168, 76, 0.55);
    border-radius: 16px;
    padding: 28px 24px;
    margin-bottom: 36px;
    text-align: left;
  }

  .reading-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    color: #c9a84c;
    margin: 0 0 16px;
  }

  .reading-text p {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(17px, 4.5vw, 20px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 16px;
  }

  .reading-text p:last-child { margin-bottom: 0; }

  .divider {
    width: 36px;
    height: 0.5px;
    background: rgba(201, 168, 76, 0.4);
    margin: 0 auto 36px;
  }

  .convert {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .convert-headline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 26px;
    line-height: 1.3;
    color: #faf8f3;
    margin: 0 0 14px;
  }

  .convert-headline em {
    font-style: italic;
    color: #c9a84c;
  }

  .convert-body {
    font-family: 'Raleway', sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    max-width: 340px;
    margin: 0 0 28px;
  }

  .footer-mark {
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.18);
    letter-spacing: 1px;
    margin-top: 40px;
  }

  @media (max-width: 480px) {
    .hero { height: 58vh; min-height: 360px; }
    .hero-title { font-size: 26px; }
    .reading-text p { font-size: 16px; }
  }
</style>
