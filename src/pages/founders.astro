---
import MinimalLayout from '../layouts/MinimalLayout.astro';
---

<MinimalLayout
  title="Founders Access · Whisp"
  description="Lock in premium access at the founders price — before Whisp goes wide."
  ogUrl="https://getwhisp.app/founders"
>

<section class="founders-page">

  <!-- Hero -->
  <div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-wordmark">✦ whisp</div>
    <div class="hero-content">
      <p class="eyebrow">FOUNDERS ACCESS</p>
      <h1 class="headline">
        Be among the first<br/>
        <em>to hear every sign.</em>
      </h1>
      <p class="sub">
        Lock in full premium — journals, AI reflections, dream archetypes,
        celestial context, and everything we build next. At the founders rate.
      </p>
    </div>
  </div>

  <!-- Offer card -->
  <div class="offer-wrap">
    <div class="offer-card">
      <p class="offer-eyebrow">✦ FOUNDERS PRICE</p>

      <!-- Plan toggle -->
      <div class="plan-toggle">
        <button class="plan-btn active" id="btn-monthly" data-plan="monthly">
          Monthly
        </button>
        <button class="plan-btn" id="btn-annual" data-plan="annual">
          Annual <span class="save-badge">SAVE 17%</span>
        </button>
      </div>

      <div class="price-row">
        <span class="price" id="price-display">$3.99</span>
        <span class="price-note" id="price-note">/month · cancel anytime</span>
      </div>

      <ul class="features">
        <li><span class="check">✓</span> Unlimited AI reflections on every sign &amp; dream</li>
        <li><span class="check">✓</span> Personalized daily insights</li>
        <li><span class="check">✓</span> Weekly AI pattern summaries</li>
        <li><span class="check">✓</span> Deep symbol &amp; archetype meanings</li>
        <li><span class="check">✓</span> AI-generated dream &amp; vision imagery</li>
        <li><span class="check">✓</span> Celestial &amp; sacred context on every log</li>
        <li><span class="check">✓</span> Sign correlations &amp; dream archetype mapping</li>
        <li><span class="check">✓</span> Full sign &amp; dream history — all time</li>
        <li><span class="check">✓</span> Gifted readings for people you love</li>
        <li><span class="check">✓</span> Everything we ship next, included</li>
      </ul>

      <form id="checkout-form">
        <input
          type="email"
          id="email-input"
          placeholder="your@email.com"
          autocomplete="email"
          required
        />
        <button type="submit" id="checkout-btn">
          <span id="btn-text">Get Founders Access ✦</span>
          <span id="btn-loading" style="display:none;">Taking you to checkout…</span>
        </button>
      </form>

      <p class="fine">
        Secure checkout via Stripe · Your account is created automatically after payment ·
        You'll receive an email to set your password.
      </p>
    </div>

    <p class="founders-note">
      ✦ Founders pricing is limited and will close when early access ends.
      Standard premium after that is $7.99/mo — this rate locks you in.
    </p>
  </div>

  <!-- Footer -->
  <p class="footer-mark">getwhisp.app</p>

</section>

<script>
  let selectedPlan = 'monthly';

  const btnMonthly = document.getElementById('btn-monthly') as HTMLButtonElement;
  const btnAnnual  = document.getElementById('btn-annual')  as HTMLButtonElement;
  const priceEl    = document.getElementById('price-display') as HTMLSpanElement;
  const noteEl     = document.getElementById('price-note')   as HTMLSpanElement;

  btnMonthly.addEventListener('click', () => {
    selectedPlan = 'monthly';
    btnMonthly.classList.add('active');
    btnAnnual.classList.remove('active');
    priceEl.textContent = '$3.99';
    noteEl.textContent  = '/month · cancel anytime';
  });

  btnAnnual.addEventListener('click', () => {
    selectedPlan = 'annual';
    btnAnnual.classList.add('active');
    btnMonthly.classList.remove('active');
    priceEl.textContent = '$39.97';
    noteEl.textContent  = '/year · cancel anytime';
  });

  const form        = document.getElementById('checkout-form') as HTMLFormElement;
  const checkoutBtn = document.getElementById('checkout-btn')  as HTMLButtonElement;
  const btnText     = document.getElementById('btn-text')      as HTMLSpanElement;
  const btnSpin     = document.getElementById('btn-loading')   as HTMLSpanElement;
  const emailInput  = document.getElementById('email-input')   as HTMLInputElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) { emailInput.focus(); return; }

    checkoutBtn.disabled = true;
    btnText.style.display = 'none';
    btnSpin.style.display = 'inline';

    try {
      const res  = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, plan: selectedPlan }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Unknown error');
      }
    } catch (err: any) {
      alert('Something went wrong: ' + err.message);
      checkoutBtn.disabled = false;
      btnText.style.display = 'inline';
      btnSpin.style.display = 'none';
    }
  });
</script>

</MinimalLayout>

<style>
  .founders-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #07041a 0%, #0e0830 40%, #050212 100%);
    color: #faf8f3;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    padding: 80px 24px 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(149,117,205,0.25) 0%, transparent 60%),
      radial-gradient(ellipse at 30% 80%, rgba(240,192,64,0.08) 0%, transparent 55%);
  }

  .hero-wordmark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 22px;
    color: rgba(255,248,235,0.6);
    letter-spacing: 1px;
    margin-bottom: 40px;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 560px;
  }

  .eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
    color: #9575CD;
    margin: 0 0 20px;
  }

  .headline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(32px, 8vw, 52px);
    line-height: 1.15;
    color: #faf8f3;
    margin: 0 0 20px;
  }

  .headline em { font-style: italic; color: #F0C040; }

  .sub {
    font-family: 'Raleway', sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    max-width: 460px;
    margin: 0 auto;
  }

  /* ── Offer card ────────────────────────────────────────────────────────── */
  .offer-wrap {
    width: 100%;
    max-width: 520px;
    padding: 0 24px 60px;
  }

  .offer-card {
    background: rgba(149,117,205,0.08);
    border: 0.5px solid rgba(149,117,205,0.3);
    border-radius: 20px;
    padding: 32px 28px;
    margin-bottom: 20px;
  }

  .offer-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2.5px;
    color: #9575CD;
    margin: 0 0 20px;
  }

  /* Plan toggle */
  .plan-toggle {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }

  .plan-btn {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 0.5px solid rgba(149,117,205,0.25);
    border-radius: 10px;
    padding: 10px 12px;
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .plan-btn.active {
    background: rgba(149,117,205,0.18);
    border-color: rgba(149,117,205,0.6);
    color: #faf8f3;
  }

  .save-badge {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #F0C040;
    background: rgba(240,192,64,0.12);
    border-radius: 4px;
    padding: 2px 5px;
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 28px;
    border-bottom: 0.5px solid rgba(149,117,205,0.2);
    padding-bottom: 24px;
  }

  .price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 56px;
    font-weight: 300;
    color: #F0C040;
    line-height: 1;
  }

  .price-note {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }

  .features {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .features li {
    font-family: 'Raleway', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.75);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.5;
  }

  .check {
    color: #F0C040;
    font-size: 12px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Form */
  #checkout-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #email-input {
    background: rgba(255,255,255,0.06);
    border: 0.5px solid rgba(149,117,205,0.35);
    border-radius: 10px;
    padding: 14px 16px;
    font-family: 'Raleway', sans-serif;
    font-size: 14px;
    color: #faf8f3;
    outline: none;
    transition: border-color 0.2s;
  }

  #email-input::placeholder { color: rgba(255,255,255,0.25); }
  #email-input:focus { border-color: rgba(149,117,205,0.65); }

  #checkout-btn {
    background: linear-gradient(135deg, #b39ddb, #9575CD, #7b52c0);
    border: none;
    border-radius: 12px;
    padding: 16px 24px;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: white;
    cursor: pointer;
    transition: opacity 0.2s;
    box-shadow: 0 6px 24px rgba(149,117,205,0.4);
  }

  #checkout-btn:hover:not(:disabled) { opacity: 0.88; }
  #checkout-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .fine {
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    color: rgba(255,255,255,0.28);
    text-align: center;
    line-height: 1.6;
    margin-top: 16px;
  }

  .founders-note {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 14px;
    color: rgba(255,255,255,0.38);
    text-align: center;
    line-height: 1.6;
  }

  .footer-mark {
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    color: rgba(255,255,255,0.15);
    letter-spacing: 1px;
    margin-bottom: 40px;
  }

  @media (max-width: 480px) {
    .hero { padding: 60px 20px 48px; }
    .offer-card { padding: 24px 20px; }
    .price { font-size: 44px; }
  }
</style>
